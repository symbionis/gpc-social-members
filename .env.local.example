# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://rmchkoktpzoojlglyfca.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Postmark
POSTMARK_SERVER_TOKEN=
# Broadcast stream id (Postmark default broadcast stream is "broadcast")
POSTMARK_BROADCAST_STREAM_ID=broadcast
# Different sender from transactional to keep deliverability separate
POSTMARK_BROADCAST_FROM="Geneva Polo Social Club" <contact@genevapolo.com>
# Shared secret guarding the Postmark unsubscribe webhook
POSTMARK_WEBHOOK_TOKEN=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# PostHog product analytics + error tracking (web)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
# Build-time only: personal API key + environment ID for source-map upload.
# Source maps are uploaded only when BOTH are set; safe to leave blank locally.
POSTHOG_PERSONAL_API_KEY=
POSTHOG_ENV_ID=

# Agent API (server-only; rotate by changing this value)
AGENT_API_TOKEN=
